# Novel-writing domain profile.
# Copy to profiles/novel/.env.novel and edit the absolute path.
#
# Shared secrets (ROBOCO_ENCRYPTION_KEY, ROBOCO_AGENT_AUTH_SECRET, host auth
# dirs) stay in the repo-root .env and are loaded first by run-profile.sh.
# This file holds ONLY the settings that differ per domain.

# Separate database — isolated from research and from the default `roboco` DB.
ROBOCO_DATABASE_NAME=roboco_novel

# Separate data root — isolates workspaces / generated prompts / logs / manifests.
# (Already `${ROBOCO_DATA_DIR:-./data}` in docker-compose.yaml.)
ROBOCO_DATA_DIR=./data-novel

# Absolute host path of the SAME dir, for docker-in-docker agent mounts.
# Must point at <repo>/data-novel on the host. EDIT THIS.
ROBOCO_HOST_DATA_DIR=/ABSOLUTE/PATH/TO/roboco/data-novel
