# Research-writing domain profile.
# Copy to profiles/research/.env.research and edit the absolute path.
#
# Shared secrets (ROBOCO_ENCRYPTION_KEY, ROBOCO_AGENT_AUTH_SECRET, host auth
# dirs) stay in the repo-root .env and are loaded first by run-profile.sh.
# This file holds ONLY the settings that differ per domain.

# Separate database — isolated from novel and from the default `roboco` DB.
ROBOCO_DATABASE_NAME=roboco_research

# Separate data root — isolates workspaces / generated prompts / logs / manifests.
ROBOCO_DATA_DIR=./data-research

# Absolute host path of the SAME dir, for docker-in-docker agent mounts.
# Must point at <repo>/data-research on the host. EDIT THIS.
ROBOCO_HOST_DATA_DIR=/ABSOLUTE/PATH/TO/roboco/data-research
